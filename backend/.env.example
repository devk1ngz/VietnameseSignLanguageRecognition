# Goc du an (chua src/, models/*.onnx, experiments/gloss.csv). Mac dinh la chinh thu muc
# nay nen thuong KHONG can dat. Chi ghi de neu artifact nam noi khac.
# RECOGNITION_ROOT=.

# SPOTER (ONNX)
SPOTER_ONNX_NAME=models/spoter_multicam_v3.onnx
GLOSS_CSV_NAME=experiments/gloss.csv
SPOTER_NUM_CLASSES=400
SPOTER_SEQ_LEN=70
SPOTER_CONFIDENCE_THRESHOLD=0.60
# Danh sach provider ONNX theo thu tu uu tien (JSON). Se giao voi provider san co.
SPOTER_PROVIDERS=["CUDAExecutionProvider","CPUExecutionProvider"]

# Ollama / Qwen3
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:1.7b
OLLAMA_TIMEOUT=10.0

# TTS (VieNeu). Sample rate lay tu engine luc chay; gia tri duoi chi la du phong.
TTS_MODE=standard
TTS_SAMPLE_RATE=24000

# Session buffer
SESSION_STRIDE=10

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
CORS_ALLOW_ORIGINS=["*"]
